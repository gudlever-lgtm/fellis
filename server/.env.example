DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fellis_eu
PORT=3001

# Google OAuth (optional — enables "Sign in with Google" and "Connect Google" in profile)
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Authorized JavaScript origins: https://fellis.eu
# 4. Authorized redirect URIs: https://fellis.eu/api/auth/google/callback
# 5. Enable APIs: "Google OAuth2 API" (for sign-in) and optionally "Google Picker API" (for photo picker)
# Required scopes: openid email profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://fellis.eu/api/auth/google/callback

# LinkedIn OAuth (optional — enables "Sign in with LinkedIn" and "Connect LinkedIn" in profile)
# 1. Go to https://www.linkedin.com/developers/apps → Create App
# 2. Under "Auth" tab → OAuth 2.0 settings → Authorized redirect URLs:
#    https://fellis.eu/api/auth/linkedin/callback
# 3. Under "Products" tab: request access to "Sign In with LinkedIn using OpenID Connect"
# Required scopes: openid profile email
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://fellis.eu/api/auth/linkedin/callback

# SMTP (optional — enables email sending for invites, password resets, etc.)
MAIL_HOST=smtp.migadu.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Site base URL — used in password reset links, invite links, Mollie webhooks, etc.
# For local development: http://localhost:3001
# For production:        https://fellis.eu
SITE_URL=https://fellis.eu

# 46elks SMS (required for SMS MFA)
# Sign up at https://46elks.com/ — credentials shown in the API dashboard
46ELKS_USERNAME=
46ELKS_PASSWORD=
# Sender name shown on recipient's phone (max 11 alphanumeric chars, or E.164 number)
46ELKS_SENDER=FellisEU

# CVR API (optional — enables instant business verification against the Danish Business Authority)
# Without a token: limited to 5 requests/hour (will fall back to manual review if exceeded)
# Free token (100 req/hr): register at https://cvrapi.dk/ → My account → Token
CVRAPI_TOKEN=

# Mistral AI — EU-based LLM for AI-assisted CV and cover letter generation
# Get a free API key at https://console.mistral.ai/
# Optional — falls back to template generation if not set
MISTRAL_API_KEY=

# Facebook data import (optional — enables "Import from Facebook" in Edit Profile)
# This is NOT Facebook Login — users log in to Fellis normally.
# Facebook is used only as a data source to enrich the user profile.
# 1. Go to https://developers.facebook.com/ → Create App (type: Consumer)
# 2. Add "Facebook Login" product → Web → set Site URL to https://fellis.eu
# 3. Under Facebook Login → Settings → add Valid OAuth Redirect URI:
#    https://fellis.eu/api/auth/facebook/callback
# 4. Under App Settings → Basic: copy App ID and App Secret
# 5. Under App Review: request permissions:
#    user_birthday, user_hometown, user_location, user_gender, user_age_range,
#    user_likes, user_photos, user_videos
# 6. Set Deauthorize Callback URL: https://fellis.eu/api/auth/facebook/deauthorize
# 7. Set Data Deletion Request URL: https://fellis.eu/api/auth/facebook/delete
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://fellis.eu/api/auth/facebook/callback
# FB_TOKEN_SECRET: 32-byte random hex used to encrypt fb_access_token at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Auto-generated on startup if not set, but should be set explicitly for persistence across restarts.
FB_TOKEN_SECRET=
