DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fellis_eu
PORT=3001

# Facebook OAuth (required for "Connect with Facebook")
# Create an app at https://developers.facebook.com/
# Add product: Facebook Login → Valid OAuth Redirect URIs: https://fellis.eu/api/auth/facebook/callback
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://fellis.eu/api/auth/facebook/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FB_TOKEN_ENCRYPTION_KEY=

# Google Photos (optional — enables "Pick from Google Photos" in post creator)
# Create a project at https://console.cloud.google.com/
# Enable the "Google Picker API" and create an OAuth 2.0 Client ID (Web application)
# Add https://fellis.eu as an authorized JavaScript origin
GOOGLE_CLIENT_ID=

# SMTP (optional — enables email sending for invites, password resets, etc.)
MAIL_HOST=smtp.migadu.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Site base URL — used in password reset links, invite links, Mollie webhooks, etc.
# For local development: http://localhost:3001
# For production:        https://fellis.eu
SITE_URL=https://fellis.eu

# 46elks SMS (required for SMS MFA)
# Sign up at https://46elks.com/ — credentials shown in the API dashboard
46ELKS_USERNAME=
46ELKS_PASSWORD=
# Sender name shown on recipient's phone (max 11 alphanumeric chars, or E.164 number)
46ELKS_SENDER=FellisEU
